# --- Mobile app (Expo) ---
# Cutout pipeline: disabled (default, honest fallback) | remote (calls the local backend)
EXPO_PUBLIC_CUTOUT_PROVIDER=disabled
# Backend base URL. On a physical iPhone, use the Mac LAN IP, not localhost.
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000

# Recognition pipeline: mock (default, offline) | remote (calls the local backend)
EXPO_PUBLIC_RECOGNITION_PROVIDER=mock
# Recognition backend base URL. Falls back to EXPO_PUBLIC_API_BASE_URL when unset.
EXPO_PUBLIC_RECOGNITION_API_BASE_URL=http://localhost:3000

# --- Cutout backend (server/, never shipped to mobile) ---
# disabled (default) | remove-bg
CUTOUT_PROVIDER=disabled
# Secret key, server-side only. Never prefix with EXPO_PUBLIC_.
REMOVE_BG_API_KEY=

# --- Recognition backend (server/, never shipped to mobile) ---
# mock (default) | gemini | disabled
RECOGNITION_PROVIDER=mock
# Secret key, server-side only. Never prefix with EXPO_PUBLIC_.
GEMINI_API_KEY=
GEMINI_RECOGNITION_MODEL=gemini-3.1-flash-lite
